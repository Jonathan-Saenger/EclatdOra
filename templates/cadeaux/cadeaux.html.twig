{% extends 'base.html.twig' %}

{% block title %}Cadeaux - Offrez des Séances de Bien-être{% endblock %}

{% block body %}

    <div class="mb-3">
        <div class="p-5 text-center bg-body-tertiary" style="background-image: url('{{asset('images/bandeau_cadeau.webp')}}'); background-size: cover; background-position: center; height: 300px; width: 100%">
            <div class="container pt-3">
                <h1> Offrez des Cadeaux Originaux</h1>
            </div>
        </div>
    </div>

    <section class="py-3 text-center container">
            <h2>Bons cadeaux bien-être</h2>
            <h3>Envie d'offrir un cadeau original à un proche ?</h3>
            <h3>Faites-lui découvrir le Rituel Chamanique, l'hypnose transpersonnelle ou la lumière Lucia</h3>
            <p class="lead">Pour un moment de bien-être et de sérénité, choisissez une <strong>séance de Rituel Chamanique</strong> qui invite à la libération, la transformation et le réalignement intérieur. Pour un voyage intérieur profond, offrez une <strong>hypnose transpersonnelle</strong> idéale pour l'exploration de soi. Pour une
            expérience lumineuse unique, la <strong>lumière Lucia</strong>, saura élever l'âme et apaiser les tensions. Ces expériences sont parfaites pour célébrer
            les occasions spéciales comme les anniversaires, la Saint-Valentin, Noël, ou encore la fête des Mères et des Pères.</p>
    </section>

    <div class="album py-3 fond">
        <div class="container">
            <h2 class="text-center"> Bons cadeaux pour une séance individuelle </h2>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/signature_cadeaux.webp')}}" class="bd-placeholder-img card-img-top" alt="Cadeau pour un Massage Signature" >
                        <div class="card-body text-center">
                            <h4 class="card-text">Offrez un massage</h4>
                            <h3>Massages Signature</h3>
                            <div class="pb-3">
                                <select id="signature-select" class="form-select form-select-sm" aria-label="Choix du massage signature">
                                    <option selected>Choisir votre massage</option>
                                    <option value="1">Traversée Sensorielle – 1h</option>
                                    <option value="2">Traversée Sensorielle – 2h</option>
                                    <option value="3">Voyage Céleste duo – 1h30</option>
                                    <option value="4">Voyage Céleste duo – 2h30</option>
                                    <option value="5">Expansion Intérieure – 4h</option>
                                    <option value="6">Immersion Originelle duo – 4h</option>
                                </select>
                            </div>
                            <form action="{{ path('app_panier_ajouter') }}" method="post" class="d-inline" id="signature-cadeau-form">
                                <input type="hidden" name="id" id="signature-cadeau-id" value="cadeau-massage-traversee-1h">
                                <input type="hidden" name="titre" id="signature-cadeau-titre" value="Bon cadeau - Massage Traversée Sensorielle 1h">
                                <input type="hidden" name="duree" id="signature-cadeau-duree" value="1 heure">
                                <input type="hidden" name="prix" id="signature-cadeau-prix" value="70">
                                <button type="submit" id="signature-price" class="bouton-or">Prix : 70 €</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/reiki_cadeau1.webp')}}" class="bd-placeholder-img card-img-top" alt="Cadeau pour une séance de Réiki" >
                        <div class="card-body text-center pb-4">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Reiki</h3>
                            <p> Durée : 1 heure </p>
                            {{ include('partials/_add_to_cart_button.html.twig', {
                                id: 'cadeau-reiki',
                                titre: 'Bon cadeau - Reiki',
                                duree: '1h30',
                                prix: 90,
                                label: 'Prix : 90 €'
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/services_constellation_boncadeaux.webp')}}" class="bd-placeholder-img card-img-top" alt="Cadeau pour une séance de Constellation Familiale" >
                        <div class="card-body text-center pb-4">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Constellation Familliale</h3>
                            <p> Durée : 1 heure </p>
                            {{ include('partials/_add_to_cart_button.html.twig', {
                                id: 'cadeau-constellation',
                                titre: 'Bon cadeau - Constellation Familiale',
                                duree: '1 heure',
                                prix: 125,
                                label: 'Prix : 125 €'
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/hypnose_cadeau.webp')}}" class="bd-placeholder-img card-img-top"  alt="Cadeau pour une séance d'hypnose">
                        <div class="card-body text-center pb-4">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Hypnose</h3>
                            <p> Durée : 3 heures </p>
                            {{ include('partials/_add_to_cart_button.html.twig', {
                                id: 'cadeau-hypnose',
                                titre: 'Bon cadeau - Hypnose',
                                duree: '3 heures',
                                prix: 200,
                                label: 'Prix : 200 €'
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/lucia_cadeau.webp')}}" class="bd-placeholder-img card-img-top" alt="Cadeau pour une séance de Luminothérapie" >
                        <div class="card-body text-center">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Luminothérapie</h3>
                            <div class="pb-3">
                                <select id="duration-select" class="form-select form-select-sm" aria-label="Small select example">
                                <option selected>Choisir votre durée</option>
                                <option value="1" data-prix="90" data-duree="1 heure">Individuelle 1 heure</option>
                                <option value="2" data-prix="150" data-duree="2 heures">Individuelle 2 heures</option>
                                <option value="3" data-prix="160" data-duree="1 heure">Duo 1 heure</option>
                                <option value="4" data-prix="250" data-duree="2 heures">Duo 2 heures</option>
                                </select>
                            </div>
                            <form action="{{ path('app_panier_ajouter') }}" method="post" class="d-inline" id="lucia-cadeau-form">
                                <input type="hidden" name="id" id="lucia-cadeau-id" value="cadeau-lucia-individuelle-1h">
                                <input type="hidden" name="titre" id="lucia-cadeau-titre" value="Bon cadeau - Lucia individuelle 1h">
                                <input type="hidden" name="duree" id="lucia-cadeau-duree" value="1 heure">
                                <input type="hidden" name="prix" id="lucia-cadeau-prix" value="90">
                                <button type="submit" id="lucia-price" class="bouton-or">Prix : 90 €</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/cadeau_soins.webp')}}" class="bd-placeholder-img card-img-top" alt="Cadeau pour une séance de Soin Vibratoire" >
                        <div class="card-body text-center pb-4">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Soin Vibratoire</h3>
                            <p> Durée : 1 heure </p>
                            {{ include('partials/_add_to_cart_button.html.twig', {
                                id: 'cadeau-soins',
                                titre: 'Bon cadeau - Soin Vibratoire',
                                duree: '1h à 1h30',
                                prix: 80,
                                label: 'Prix : 80 €'
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/rituel_cadeaux.webp')}}" class="bd-placeholder-img card-img-top"  alt="Cadeau pour une séance de Rituel Chamanique" >
                        <div class="card-body text-center">
                            <h4 class="card-text">Offrez une séance</h4>
                            <h3>Rituel Chamanique</h3>
                            <div class="pb-3">
                                <select id="rituel-select" class="form-select form-select-sm" aria-label="Choix du rituel chamanique">
                                    <option selected>Choisir votre rituel</option>
                                    <option value="1">Rituel d'Éveil Intérieur – 1h30</option>
                                    <option value="2">Cérémonie Initiatique Renaissance – 4h00</option>
                                </select>
                            </div>
                            <form action="{{ path('app_panier_ajouter') }}" method="post" class="d-inline" id="rituel-cadeau-form">
                                <input type="hidden" name="id" id="rituel-cadeau-id" value="cadeau-rituel-eveil-interieur">
                                <input type="hidden" name="titre" id="rituel-cadeau-titre" value="Bon cadeau - Rituel d'Éveil Intérieur">
                                <input type="hidden" name="duree" id="rituel-cadeau-duree" value="1h30">
                                <input type="hidden" name="prix" id="rituel-cadeau-prix" value="150">
                                <button type="submit" id="rituel-price" class="bouton-or">Prix : 150 €</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card m-3 h-100">
                        <img src="{{asset('images/meditation_cadeau.webp')}}" class="bd-placeholder-img card-img-top" alt="Montant libre du bon cadeau à offrir" >
                        <div class="card-body text-center">
                            <h4 class="card-text">Montant libre</h4>
                            <h3>Bon cadeau</h3>
                            <form action="{{ path('app_panier_ajouter') }}" method="post" id="montant-libre-form">
                                <div class="pb-3">
                                    <div class="input-group input-group-sm">
                                        <input id="montant-cadeau" class="form-control" type="number" name="montant-cadeau" min="15" placeholder="Votre montant (min. 15€)" required/>
                                        <span class="input-group-text">€</span>
                                    </div>
                                </div>
                                <input type="hidden" name="id" value="cadeau-montant-libre">
                                <input type="hidden" name="titre" id="montant-libre-titre" value="Bon cadeau - Montant libre">
                                <input type="hidden" name="duree" value="À définir">
                                <input type="hidden" name="prix" id="montant-libre-prix" value="15">
                                <button type="submit" class="bouton-or">Ajouter au panier</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="album py-3 fond">
        <div class="container">
            <div class="text-center mb-5">
                <h2> Les séances se déroulent dans mes locaux :</h2>
            </div>
            <div class="row g-5">
                <div class="col-lg-5 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <h3>Adresse : </h3>
                    <h4>Espace Omoondo</h4>
                    <h4> 6 rue du Général Rapp </h4>
                    <h4> 67450 Mundolsheim</h4>
                </div>
                <div class="col-lg-7 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                    <div class="row g-3">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d10546.199451537741!2d7.706118424525094!3d48.637595290846185!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4796c9015596c159%3A0x4278c5d1a1d7ef92!2sUnivers%20Quantic%20Shop!5e0!3m2!1sfr!2sfr!4v1712188198044!5m2!1sfr!2sfr" width="500" height="250" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container text-center my-5">
        <h2 class="" > Vous souhaitez en savoir plus sur mes prestations ?</h2>
        <a href="{{path('app_signature')}}" class="bouton-or m-3">Massages : Soins Signatures</a>
        <a href="{{path('app_reiki')}}" class="bouton-or m-3">Soins Reiki</a>
        <a href="{{path('app_constellation')}}" class="bouton-or m-3">Constellation familiale et systémique</a>
        <a href="{{path('app_hypnose')}}" class="bouton-or m-3">Hypnose</a>
        <a href="{{path('app_lucia')}}" class="bouton-or m-3">Luminothérapie</a>
        <a href="{{path('app_soins')}}" class="bouton-or m-3">Sonothérapie</a>
        <a href="{{path('app_rituel')}}" class="bouton-or m-3">Rituel Chamanique</a>
    </div>

<script>
    // Configuration Lucia pour les bons cadeaux
    const luciaConfig = {
        1: { prix: 90, duree: "1 heure", id: "cadeau-lucia-individuelle-1h", titre: "Bon cadeau - Lucia individuelle 1h" },
        2: { prix: 150, duree: "2 heures", id: "cadeau-lucia-individuelle-2h", titre: "Bon cadeau - Lucia individuelle 2h" },
        3: { prix: 160, duree: "1 heure", id: "cadeau-lucia-duo-1h", titre: "Bon cadeau - Lucia duo 1h" },
        4: { prix: 250, duree: "2 heures", id: "cadeau-lucia-duo-2h", titre: "Bon cadeau - Lucia duo 2h" }
    };
    
    const selectElement = document.getElementById("duration-select");
    const priceButton = document.getElementById("lucia-price");
    const luciaIdInput = document.getElementById("lucia-cadeau-id");
    const luciaTitreInput = document.getElementById("lucia-cadeau-titre");
    const luciaDureeInput = document.getElementById("lucia-cadeau-duree");
    const luciaPrixInput = document.getElementById("lucia-cadeau-prix");

    selectElement.addEventListener("change", () => {
        const selectedValue = selectElement.value;
        const config = luciaConfig[selectedValue];
        
        if (config) {
            priceButton.textContent = `Prix : ${config.prix} €`;
            luciaIdInput.value = config.id;
            luciaTitreInput.value = config.titre;
            luciaDureeInput.value = config.duree;
            luciaPrixInput.value = config.prix;
        }
    });

    // Configuration Massages Signature pour les bons cadeaux
    const signatureConfig = {
        1: { prix: 70, duree: "1 heure", id: "cadeau-massage-traversee-1h", titre: "Bon cadeau - Massage Traversée Sensorielle 1h" },
        2: { prix: 140, duree: "2 heures", id: "cadeau-massage-traversee-2h", titre: "Bon cadeau - Massage Traversée Sensorielle 2h" },
        3: { prix: 130, duree: "1h30", id: "cadeau-massage-voyage-celeste-1h30", titre: "Bon cadeau - Massage duo Voyage Céleste 1h30" },
        4: { prix: 200, duree: "2h30", id: "cadeau-massage-voyage-celeste-2h30", titre: "Bon cadeau - Massage duo Voyage Céleste 2h30" },
        5: { prix: 350, duree: "4 heures", id: "cadeau-massage-expansion-interieure", titre: "Bon cadeau - Massage Expansion Intérieure 4h" },
        6: { prix: 350, duree: "4 heures", id: "cadeau-massage-immersion-originelle", titre: "Bon cadeau - Massage duo Immersion Originelle 4h" }
    };

    const signatureSelect = document.getElementById("signature-select");
    const signaturePriceButton = document.getElementById("signature-price");
    const signatureIdInput = document.getElementById("signature-cadeau-id");
    const signatureTitreInput = document.getElementById("signature-cadeau-titre");
    const signatureDureeInput = document.getElementById("signature-cadeau-duree");
    const signaturePrixInput = document.getElementById("signature-cadeau-prix");

    signatureSelect.addEventListener("change", () => {
        const selectedValue = signatureSelect.value;
        const config = signatureConfig[selectedValue];
        
        if (config) {
            signaturePriceButton.textContent = `Prix : ${config.prix} €`;
            signatureIdInput.value = config.id;
            signatureTitreInput.value = config.titre;
            signatureDureeInput.value = config.duree;
            signaturePrixInput.value = config.prix;
        }
    });

    // Configuration Rituel Chamanique pour les bons cadeaux
    const rituelConfig = {
        1: { prix: 150, duree: "1h30", id: "cadeau-rituel-eveil-interieur", titre: "Bon cadeau - Rituel d'Éveil Intérieur" },
        2: { prix: 300, duree: "4h00", id: "cadeau-rituel-ceremonie-renaissance", titre: "Bon cadeau - Cérémonie Initiatique Renaissance" }
    };

    const rituelSelect = document.getElementById("rituel-select");
    const rituelPriceButton = document.getElementById("rituel-price");
    const rituelIdInput = document.getElementById("rituel-cadeau-id");
    const rituelTitreInput = document.getElementById("rituel-cadeau-titre");
    const rituelDureeInput = document.getElementById("rituel-cadeau-duree");
    const rituelPrixInput = document.getElementById("rituel-cadeau-prix");

    rituelSelect.addEventListener("change", () => {
        const selectedValue = rituelSelect.value;
        const config = rituelConfig[selectedValue];
        
        if (config) {
            rituelPriceButton.textContent = `Prix : ${config.prix} €`;
            rituelIdInput.value = config.id;
            rituelTitreInput.value = config.titre;
            rituelDureeInput.value = config.duree;
            rituelPrixInput.value = config.prix;
        }
    });

    // Gestion du bon cadeau à montant libre
    const montantCadeauInput = document.getElementById("montant-cadeau");
    const montantLibrePrixInput = document.getElementById("montant-libre-prix");
    const montantLibreTitreInput = document.getElementById("montant-libre-titre");

    montantCadeauInput.addEventListener("input", () => {
        const montant = parseFloat(montantCadeauInput.value) || 15;
        montantLibrePrixInput.value = montant;
        montantLibreTitreInput.value = `Bon cadeau - ${montant} €`;
    });

    // Validation du montant minimum avant soumission
    document.getElementById("montant-libre-form").addEventListener("submit", (e) => {
        const montant = parseFloat(montantCadeauInput.value);
        if (!montant || montant < 15) {
            e.preventDefault();
            alert("Le montant minimum est de 15 €");
            return false;
        }
    });
</script>

{% endblock %}
